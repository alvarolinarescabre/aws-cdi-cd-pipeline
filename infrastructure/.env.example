# Configuración de Variables - AWS Pipeline
# Reemplaza los valores con los tuyos propios

# AWS Account ID (ID de cuenta AWS - 12 dígitos)
AWS_ACCOUNT_ID=123456789012

# Región AWS (ej: us-east-1, eu-west-1)
AWS_DEFAULT_REGION=us-east-1

# Nombre del repositorio ECR
IMAGE_REPO_NAME=mi-app-repo

# URI completa ECR (se forma así: $AWS_ACCOUNT_ID.dkr.ecr.$AWS_DEFAULT_REGION.amazonaws.com/$IMAGE_REPO_NAME)
ECR_REPOSITORY_URI=123456789012.dkr.ecr.us-east-1.amazonaws.com/mi-app-repo

# Nombres de recursos en AWS
ECS_CLUSTER_NAME=mi-cluster-ecs
ECS_SERVICE_NAME=mi-servicio-ecs
ECS_TASK_DEFINITION=mi-task-def
ECS_CONTAINER_NAME=mi-contenedor-app

# GitHub
GITHUB_REPO_OWNER=tu-usuario
GITHUB_REPO_NAME=tu-repo
GITHUB_BRANCH=main

# CodePipeline
CODEPIPELINE_NAME=mi-pipeline-github
CODEBUILD_PROJECT_NAME=mi-proyecto-build
CODEBUILD_BUILDSPEC_PATH=services/pipeline/buildspec.yml

# Puerto de la aplicación
APP_PORT=80
